#!/usr/bin/env bash
# 0-change_your_home_IP - Configures localhost to 127.0.0.2 and facebook.com to 8.8.8.8

# Create a temporary file
tmpfile=$(mktemp)

# Change localhost IP from 127.0.0.1 to 127.0.0.2
sed 's/127\.0\.0\.1/127.0.0.2/g' /etc/hosts > "$tmpfile"

# Remove any existing facebook.com entry
sed -i '/facebook\.com/d' "$tmpfile"

# Add the new facebook.com mapping
echo "8.8.8.8 facebook.com" >> "$tmpfile"

# Overwrite /etc/hosts (no rename, works on busy filesystems)
cp "$tmpfile" /etc/hosts

# Clean up
rm "$tmpfile"
