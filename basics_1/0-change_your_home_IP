#!/usr/bin/env bash
# 0-change_your_home_IP - Configures localhost to 127.0.0.2 and facebook.com to 8.8.8.8

# Change localhost IPv4 mapping from 127.0.0.1 to 127.0.0.2
sudo sed -i '/localhost/ s/127\.0\.0\.1/127\.0\.0\.2/g' /etc/hosts

# Remove any existing facebook.com entry, then add the new mapping
sudo sed -i '/facebook\.com/d' /etc/hosts
echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts > /dev/null
